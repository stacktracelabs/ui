{
  "name": "@stacktrace/ui",
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "vue-tsc --build --force",
    "registry:generate": "node scripts/generate-registry.mjs",
    "docs:dev": "composer --working-dir=docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "php docs/artisan serve"
  },
  "main": "./dist/ui.js",
  "types": "./dist/types/resources/js/main.d.ts",
  "files": [
    "dist",
    "resources/js"
  ],
  "exports": {
    ".": {
      "import": "./dist/ui.js",
      "types": "./dist/types/resources/js/main.d.ts"
    }
  },
  "dependencies": {
    "@inertiajs/vue3": "^3.6.1",
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.24.0",
    "@unovis/vue": "^1.6.7",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lodash": "^4.18.1",
    "query-string": "^9.2.2",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.39",
    "vue-input-otp": "^0.3.2",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash": "^4.17.10",
    "@types/node": "^24.10.15",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "typescript": "~5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.2.5"
  }
}
