{
  "name": "@stacktrace/ui",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "vue-tsc --build --force",
    "test": "vitest run",
    "registry:generate": "node scripts/generate-registry.mjs",
    "docs:dev": "composer --working-dir=docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "php docs/artisan serve"
  },
  "main": "./dist/ui.js",
  "types": "./dist/types/resources/js/main.d.ts",
  "files": [
    "dist",
    "resources/js"
  ],
  "exports": {
    ".": {
      "import": "./dist/ui.js",
      "types": "./dist/types/resources/js/main.d.ts"
    }
  },
  "dependencies": {
    "@inertiajs/core": "^3.6.1",
    "@inertiajs/vue3": "^3.6.1",
    "@vueuse/core": "^14.3.0",
    "lodash": "^4.18.1",
    "query-string": "^9.4.1",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "happy-dom": "^20.10.6",
    "typescript": "~5.9.0",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
