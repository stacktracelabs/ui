{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "run-s registry:build build:app",
        "build:app": "run-p type-check \"build-only {@}\" --",
        "build-only": "vite build",
        "dev": "vite",
        "predev": "npm run registry:build",
        "registry:build": "node ../scripts/generate-registry.mjs --source ../components --output public/r",
        "type-check": "vue-tsc --build"
    },
    "devDependencies": {
        "@shikijs/langs": "^4.3.1",
        "@shikijs/themes": "^4.3.1",
        "@tailwindcss/vite": "^4.0.0",
        "@tsconfig/node24": "^24.0.4",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.13.2",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "concurrently": "^10.0.3",
        "laravel-vite-plugin": "^3.1",
        "npm-run-all2": "^8.0.4",
        "shiki": "^4.3.1",
        "tailwindcss": "^4.0.0",
        "typescript": "~6.0.0",
        "vite": "^8.0.16",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vue-tsc": "^3.3.4"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.4.0",
        "@internationalized/date": "^3.12.2",
        "@lucide/vue": "^1.18.0",
        "@unovis/vue": "^1.6.7",
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "embla-carousel-vue": "^8.6.0",
        "lodash": "^4.18.1",
        "reka-ui": "^2.9.10",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "vaul-vue": "^0.4.1",
        "vue": "^3.5.38",
        "vue-input-otp": "^0.3.2",
        "vue-sonner": "^2.0.9",
        "ziggy-js": "^2.6.2"
    }
}
