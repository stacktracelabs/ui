{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "shadcn-vue": {
            "command": "npx",
            "args": [
                "shadcn-vue@latest",
                "mcp"
            ]
        }
    }
}
