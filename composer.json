{
    "name": "stacktrace/ui",
    "description": "Component library for Laravel, Vue and Inertia.js based on shadcn-vue.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0",
        "inertiajs/inertia-laravel": "^2.0|^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "StackTrace\\Ui\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "StackTrace\\Ui\\Providers\\UiServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "stacktrace/ui-icons-lucide": "Required to use the Icon component with Lucide icon pack."
    }
}
